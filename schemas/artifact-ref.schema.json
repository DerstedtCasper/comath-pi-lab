{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://comath.local/schemas/artifact-ref.schema.json",
  "title": "ArtifactRef",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "project_id", "path", "kind", "sha256", "created_at"],
  "properties": {
    "id": { "type": "string", "pattern": "^[A-Z]+-[0-9]{4,}$" },
    "project_id": { "type": "string", "pattern": "^[A-Z]+-[0-9]{4,}$" },
    "path": { "type": "string", "minLength": 1 },
    "kind": {
      "type": "string",
      "enum": [
        "log",
        "paper",
        "tex",
        "bibtex",
        "pdf",
        "notebook",
        "code",
        "screenshot",
        "runner_output",
        "snapshot",
        "other"
      ]
    },
    "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "size_bytes": { "type": "integer", "minimum": 0 },
    "created_at": { "type": "string", "format": "date-time" }
  }
}

