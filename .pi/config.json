{
  "schema_version": 1,
  "profile": "local-production-formal-workbench",
  "secrets_policy": {
    "contains_secrets": false,
    "secret_files_must_not_be_committed": true,
    "local_override_example": ".pi/local.user.example.json",
    "recommended_local_override": ".pi/local.user.json"
  },
  "comathd": {
    "baseUrl": "http://127.0.0.1:48731",
    "serve_command_dev_fallback": "node ./services/comathd/dist/cli.js serve --host 127.0.0.1 --port 48731",
    "mutation_gateway": "all trusted project mutations go through comathd"
  },
  "pi_extension": {
    "package_name": "@comath/pi-extension",
    "project_settings_package_source": "../extensions/comath-pi",
    "local_install_path": "./extensions/comath-pi",
    "package_manifest": "extensions/comath-pi/package.json#pi.extensions",
    "extension_entry": "./dist/pi-extension.js",
    "registration_api": [
      "pi.registerTool",
      "pi.registerCommand",
      "pi.on(tool_call)"
    ],
    "tool_execution": "default Pi entry maps supported tools to local comathd HTTP routes",
    "resource_roots": {
      "agents": "./.pi/agents",
      "prompts": "./.pi/prompts",
      "skills": "./skills"
    }
  },
  "sdk_orchestration": {
    "preferred_entrypoints": [
      "Pi SDK createAgentSession with DefaultResourceLoader",
      "Pi RPC mode"
    ],
    "research_start_tool": "comath.research.start",
    "research_start_routes": [
      "POST /project/init",
      "POST /workstream/spawn"
    ],
    "control_surface": [
      "service",
      "project",
      "claim",
      "evidence",
      "artifact",
      "workstream",
      "graph-patch",
      "memory",
      "literature",
      "paper",
      "snapshot",
      "replay",
      "status"
    ],
    "headless_policy": "headless contexts must not call Pi UI APIs and must fail closed without an explicit confirmation policy"
  },
  "development_cli_fallback": {
    "product_contract": false,
    "expected_commands_after_install_or_link": [
      "comathd serve",
      "comath-lab research start"
    ],
    "checkout_entrypoint": "node ./services/comathd/dist/cli.js"
  },
  "safety_boundaries": {
    "pi_packages_have_local_machine_permissions": true,
    "no_secrets_in_repo_config": true,
    "triviumdb": "optional derived index only; fall back when unavailable",
    "mathprove": "evidence producer and gate runner; not proof authority",
    "promotion_gate": "fail closed without required evidence"
  }
}
